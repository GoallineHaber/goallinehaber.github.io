":"Entrenamientos","tag":["realmadrid-com:noticias/futbol/primer-equipo/entrenamientos"]},{"label":"Partes médicos","tag":["realmadrid-com:noticias/futbol/primer-equipo/partes-medicos"]},{"label":"Reportajes","tag":["realmadrid-com:noticias/futbol/primer-equipo/reportajes"]},{"label":"Personalidades","tag":["realmadrid-com:noticias/futbol/primer-equipo/personalidades"]},{"label":"Fichajes","tag":["realmadrid-com:noticias/futbol/primer-equipo/fichajes"]},{"label":"Especiales","tag":["realmadrid-com:noticias/futbol/primer-equipo/especiales"]},{"label":"Veteranos","tag":["realmadrid-com:noticias/futbol/primer-equipo/veteranos"]}]},{"label":"Primer equipo femenino","tag":["realmadrid-com:noticias/futbol/primer-equipo-femenino"],"categories":[]},{"label":"Cantera","tag":["realmadrid-com:noticias/futbol/cantera-masculina"],"categories":[]},{"label":"Cantera Femenina","tag":["realmadrid-com:noticias/futbol/cantera-femenina"],"categories":[]}]}]}}}},"h":{},"s":200,"st":"OK","u":"https://publish.realmadrid.com/graphql/execute.json/realmadridmastersite/news-section-detail-assembly%3Bpath=/content/dam/portals/realmadrid-com/es-es/core-content/assemblies/news-sections/futbol/detalle-seccion-futbol","rt":"json"},"3955511369":{"b":{"data":{"newsList":{"items":[{"slug":"cumpleanos-de-arda-guler-25-02-2024","_path":"/content/dam/portals/realmadrid-com/de-de/news/generic/2024/02/25/noticias/not--cumplea-os-de-arda-guler","title":"Arda Güler wird 19 Jahre alt","newsType":"generic","isVideoNews":false,"showRankingOpta":null,"highlightedImage":null,"image":{"__typename":"ImageRef","_publishUrl":"https://publish.realmadrid.com/content/dam/portals/realmadrid-com/es-es/news/generic/2024/02/25/fotos/ND-ARDA-TROFEO-SUPERCOPA-_AV31914.jpg","_dynamicUrl":"/adobe/dynamicmedia/deliver/dm-aid--653a2e79-ecc6-46ce-a19f-a6dabbdc8c22/ND_ARDA_TROFEO_SUPERCOPA__AV31914.webp?preferwebp=true","_dmS7Url":"https://assets.realmadrid.com/is/image/realmadrid/ND-ARDA-TROFEO-SUPERCOPA-_AV31914"},"date":"2024-02-25T07:00:00.000Z","tag":["realmadrid-com:noticias/futbol/primer-equipo/actualidad"],"photographer":null,"redactor":null,"intro":{"html":"\u003Cp>Der türkische Mittelfeldspieler spielt seine erste Saison bei Real Madrid.\u003C/p>\n","plaintext":"Der türkische Mittelfeldspieler spielt seine erste Saison bei Real Madrid."},"bodyList":[{"html":"\u003Cp>\u003Cb>Arda Güler\u003C/b>&nbsp;wird heute 19 Jahre alt. Der Mittelfeldspieler, der seine erste Saison im Kader von&nbsp;\u003Cb>Real Madrid&nbsp;\u003C/b>spielt, wurde am 25. Februar 2005 in Ankara (Türkei) geboren und wechselte im vergangenen Sommer von Fenerbahçe zu unserem Verein.\u003Cbr>\n&nbsp;\u003Cbr>\n\u003Cb>Arda Güler&nbsp;\u003C/b>debütierte im vergangenen Januar gegen Arandina im&nbsp;\u003Cb>Königspokal\u003C/b>. Seitdem hat er in drei verschiedenen Wettbewerben gespielt (er gab auch sein Debüt in&nbsp;\u003Cb>La Liga\u003C/b>&nbsp;und im\u003Cb>&nbsp;spanischen\u003C/b>&nbsp;\u003Cb>Supercup\u003C/b>) und hat seinen ersten Titel als Spieler von Real Madrid mit dem spanischen Supercup gewonnen.&nbsp;Er ist ebenfalls Nationalspieler für die Türkei.\u003C/p>\n","plaintext":"Arda Güler wird heute 19 Jahre alt. Der Mittelfeldspieler, der seine erste Saison im Kader von Real Madrid spielt, wurde am 25. Februar 2005 in Ankara (Türkei) geboren und wechselte im vergangenen Sommer von Fenerbahçe zu unserem Verein.\n\nArda Güler debütierte im vergangenen Januar gegen Arandina im Königspokal. Seitdem hat er in drei verschiedenen Wettbewerben gespielt (er gab auch sein Debüt in La Liga und im spanischen Supercup) und hat seinen ersten Titel als Spieler von Real Madrid mit dem spanischen Supercup gewonnen. Er ist ebenfalls Nationalspieler für die Türkei."}],"videoList":[{"__typename":"MultimediaRef","_publishUrl":"https://publish.realmadrid.com/content/dam/portals/realmadrid-com/es-es/news/generic/2024/02/25/v%C3%ADdeos/120224%20S7%20WEB%20CUMPLEA%C3%91OS%20GULER.mp4","_dmS7Url":"https://assets.realmadrid.com/is/content/realmadrid/120224 S7 WEB CUMPLEAÑOS GULER"}],"gallery":[],"match":null,"sponsor":null,"relatedContent":[],"seoTitle":"Arda Güler wird 19 Jahre alt","seoDescription":"Der türkische Mittelfeldspieler spielt seine erste Saison bei Real Madrid.","seoRobots":null,"seoCanonical":"https://www.realmadrid.com/de-DE/news/football/erste-mannshaft/latest-news/cumpleanos-de-arda-guler-25-02-2024","seoHrefLang":null,"lastmod":"2024-02-24T23:03:22.782Z"}]}}},"h":{},"s":200,"st":"OK","u":"https://publish.realmadrid.com/graphql/execute.json/realmadridmastersite/newsBySlugV2%3Balang=/content/dam/portals/realmadrid-com/de-de/news/%3Bslug=cumpleanos-de-arda-guler-25-02-2024","rt":"json"},"4164057524":{"b":{"realmadrid":{"url":"https://www.realmadrid.com/es-ES","es-ES":{"url":"https://www.realmadrid.com/es-ES"},"en-US":{"url":"https://www.realmadrid.com/en-US"},"ar-AE":{"url":"https://www.realmadrid.com/ar-AE"},"de-DE":{"url":"https://www.realmadrid.com/de-DE"},"fr-FR":{"url":"https://www.realmadrid.com/fr-FR"},"hi-IN":{"url":"https://www.realmadrid.com/hi-IN"},"ja-JP":{"url":"https://www.realmadrid.com/ja-JP"},"pt-PT":{"url":"https://www.realmadrid.com/pt-PT"}},"termsNfl":{"url":"https://www.nfl.com/legal/terms/es","es-ES":{"url":"https://www.nfl.com/legal/terms/es"},"en-US":{"url":"https://www.nfl.com/legal/terms/"}},"privacyPolicyNfl":{"url":"https://www.nfl.com/legal/privacy/es","es-ES":{"url":"https://www.nfl.com/legal/privacy/es"},"en-US":{"url":"https://www.nfl.com/legal/privacy/"}},"generalConditionsRoute":{"url":"https://www.realmadrid.com/es-ES/legal/aviso-legal","es-ES":{"url":"https://www.realmadrid.com/es-ES/legal/aviso-legal"},"en-US":{"url":"https://www.realmadrid.com/en-US/legal/legal-notice"},"ar-AE":{"url":"https://www.realmadrid.com/ar-AE/legal/legal-notice"},"de-DE":{"url":"https://www.realmadrid.com/de-DE/legal/rechtlicher-hinweis"},"fr-FR":{"url":"https://www.realmadrid.com/fr-FR/legal/avis-legal"},"hi-IN":{"url":"https://www.realmadrid.com/hi-IN/legal/legal-no